# Vercel Postgres connection string.
# When you create a Postgres database in the Vercel dashboard and link it to the
# project, Vercel auto-generates these variables. For local development run:
#   vercel env pull .env.local
# which writes the real values into .env.local for you.

POSTGRES_URL="postgres://user:password@host:5432/dbname?sslmode=require"
